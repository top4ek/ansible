app_env: {{ shizoidgo.app_env }}
log_level: {{ shizoidgo.log_level }}

database:
  host: {{ shizoidgo.database.host }}
  port: "{{ shizoidgo.database.port }}"
  name: {{ shizoidgo.database.name }}
  user: {{ shizoidgo.database.user }}
  password: {{ shizoidgo.database.password }}

telegram:
  token: "{{ shizoidgo.telegram.token }}"
{% if shizoidgo.telegram.webhook_url is defined %}
  webhook_url: "{{ shizoidgo.telegram.webhook_url }}"
{% endif %}
{% if shizoidgo.telegram.webhook_secret_token is defined %}
  webhook_secret_token: "{{ shizoidgo.telegram.webhook_secret_token }}"
{% endif %}

sentry:
  dsn: "{{ shizoidgo.sentry.dsn }}"
  environment: {{ shizoidgo.sentry.environment }}
{% if shizoidgo.sentry.release is defined %}
  release: "{{ shizoidgo.sentry.release }}"
{% endif %}

app:
  allow_to_all: {{ shizoidgo.app.allow_to_all | lower }}
  bot_owners:
{% for owner in shizoidgo.app.bot_owners %}
    - {{ owner }}
{% endfor %}
  bind_to: {{ shizoidgo.app.bind_to }}
  locale: {{ shizoidgo.app.locale }}
  generation_mode: {{ shizoidgo.app.generation_mode }}
  winner_cron: "{{ shizoidgo.app.winner_cron }}"
  idle_cron: "{{ shizoidgo.app.idle_cron }}"
  memory_cron: "{{ shizoidgo.app.memory_cron }}"
{% if shizoidgo.neural is defined %}

neural:
{% for mode, providers in shizoidgo.neural.items() %}
  {{ mode }}:
{% for provider in providers %}
    - name: {{ provider.name }}
      base_url: {{ provider.base_url }}
{% if provider.api_key is defined %}
      api_key: {{ provider.api_key }}
{% endif %}
      model: {{ provider.model }}
      context_size: {{ provider.context_size }}
      timeout_seconds: {{ provider.timeout_seconds }}
{% endfor %}
{% endfor %}
{% endif %}
